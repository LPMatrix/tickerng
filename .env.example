# Clerk auth (required). Install via Vercel Marketplace or create at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
# After sign-in / sign-up when the user had no return URL (matches SignIn/SignUp fallbackRedirectUrl)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/research
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/research

# Research agent — optional external override (POST `/`). If unset:
# - Vercel: uses same-deployment Python at `/api/research-agent` (see api/research-agent.py).
# - Local next dev: http://127.0.0.1:8788/ via concurrently + serve.py.
# RESEARCH_AGENT_URL=https://your-agent.up.railway.app
# RESEARCH_AGENT_URL=http://127.0.0.1:8788
# RESEARCH_AGENT_PORT=8788
# Optional: interpreter for scripts/dev-research-agent.mjs when `python3` is not on PATH.
# PYTHON_PATH=/usr/local/bin/python3

# Optional: same value as Vercel → Deployment Protection → “Protection Bypass for Automation”.
# Lets /api/research attach x-vercel-protection-bypass when server-fetching /api/research-agent on password-protected previews.
# VERCEL_AUTOMATION_BYPASS_SECRET=

# OpenRouter (required for LLM calls). Sign up at https://openrouter.ai — free $5 credit, no card needed
OPENROUTER_API_KEY=sk-or-...
# Model id on OpenRouter (e.g. anthropic/claude-sonnet-4.6). Defaults to anthropic/claude-sonnet-4.6 if unset.
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# Seconds per blocking read while streaming SSE from OpenRouter (long gaps between tokens). Default 600.
# OPENROUTER_STREAM_READ_TIMEOUT=600

# Prompt caching (Anthropic via OpenRouter). OPENROUTER_PROMPT_CACHE_ENABLED is read only if TOP_LEVEL is true.
# Top-level cache_control often causes HTTP 400 (specialists + streaming). Default OFF — set TOP_LEVEL=true only if OpenRouter confirms support.
# OPENROUTER_PROMPT_CACHE_TOP_LEVEL=false
# OPENROUTER_PROMPT_CACHE_ENABLED=true
# Cache TTL: "5m" (default) or "1h"
# OPENROUTER_PROMPT_CACHE_TTL=1h

# Tavily API key (required for web search in research). Create at https://tavily.com/
TAVILY_API_KEY=
# Optional: "basic" (faster, default) or "advanced" (deeper retrieval, more API usage). When unset, filing/market/sentiment-deep passes still use "advanced" internally.
# TAVILY_SEARCH_DEPTH=advanced

# Database: local file SQLite via libSQL (default ./data/tickerng.db), or Turso in production
# DATABASE_PATH=
# Turso (libSQL) — set in Vercel for production. Create DB: https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# Optional: Canonical site URL for SEO (sitemap, robots, Open Graph). Default: https://www.tickerng.com
# NEXT_PUBLIC_APP_URL=https://www.tickerng.com

# Paystack billing (required for paid plan). Create at https://dashboard.paystack.com
# 1. Create a "Pro" recurring plan at ₦10,000/month — copy the plan code (PLN_...)
# 2. Add your secret key from Settings → API Keys & Webhooks
# 3. Set the webhook URL to: https://your-domain.com/api/webhooks/paystack
PAYSTACK_SECRET_KEY=sk_test_...
PAYSTACK_PLAN_CODE=PLN_...

# Langfuse (optional). Tracing keys power Next.js instrumentation; same keys enable Python prompt overrides.
# Create a project at https://cloud.langfuse.com — add **text** prompts named:
#   tickerng-core-rules, tickerng-specialist-core, tickerng-synthesis-system, tickerng-ticker-extract
# (Production label). When unset or fetch fails, the agent uses in-repo defaults (`api/agent/prompt_fallbacks.py`).
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_PROMPTS_ENABLED=true
# LANGFUSE_PROMPT_LABEL=production
# Server-side cache TTL for fetched prompts (seconds). Default 300.
# LANGFUSE_PROMPT_CACHE_TTL_SECONDS=300
