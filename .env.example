# Clerk auth (required). Install via Vercel Marketplace or create at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
# After sign-in / sign-up when the user had no return URL (matches SignIn/SignUp fallbackRedirectUrl)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/research
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/research

# OpenRouter (required for LLM calls). Sign up at https://openrouter.ai — free $5 credit, no card needed
OPENROUTER_API_KEY=sk-or-...
# Model id on OpenRouter (e.g. anthropic/claude-sonnet-4.6). Defaults to anthropic/claude-sonnet-4.6 if unset.
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6

# Tavily API key (required for web search in research). Create at https://tavily.com/
TAVILY_API_KEY=
# Optional: "basic" (faster, default) or "advanced" (deeper retrieval, more API usage). When unset, filing/market/sentiment-deep passes still use "advanced" internally.
# TAVILY_SEARCH_DEPTH=advanced

# Database: local file SQLite via libSQL (default ./data/tickerng.db), or Turso in production
# DATABASE_PATH=
# Turso (libSQL) — set in Vercel for production. Create DB: https://turso.tech
# TURSO_DATABASE_URL=libsql://your-db-name-org.turso.io
# TURSO_AUTH_TOKEN=eyJ...

# Optional: Canonical site URL for SEO (sitemap, robots, Open Graph). Default: https://www.tickerng.com
# NEXT_PUBLIC_APP_URL=https://www.tickerng.com

# Stripe billing (required for paid plan). Create at https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Langfuse observability (optional). Create a project at https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
