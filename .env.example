# Clerk auth (required). Install via Vercel Marketplace or create at https://clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/signin
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
# After sign-in / sign-up when the user had no return URL (matches SignIn/SignUp fallbackRedirectUrl)
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/research
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/research

# OpenRouter (required for LLM calls). Sign up at https://openrouter.ai — free $5 credit, no card needed
OPENROUTER_API_KEY=sk-or-...

# Tavily API key (required for web search in research). Create at https://tavily.com/
TAVILY_API_KEY=

# Optional: SQLite database path (default: ./data/equiscan.db)
# DATABASE_PATH=

# Optional: Canonical site URL for SEO (sitemap, robots, Open Graph). Default: https://equiscan.app
# NEXT_PUBLIC_APP_URL=https://equiscan.app

# Stripe billing (required for paid plan). Create at https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Langfuse observability (optional). Create a project at https://cloud.langfuse.com
# LANGFUSE_SECRET_KEY=sk-lf-...
# LANGFUSE_PUBLIC_KEY=pk-lf-...
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
